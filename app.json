{
  "expo": {
    "name": "NomadWay",
    "slug": "nomadway",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a4d3a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nomadway.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a4d3a"
      },
      "package": "com.nomadway.app",
      "usesCleartextTraffic": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBcXDT9BtyUuIAFkvhuiTdebML2clW-a7M"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow NomadWay to use your location."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NomadWay to access your camera to recognize landmarks."
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "https://nomadsway.kz",
      "googleClientIdWeb": "809036959951-fd9u7f6fb56ta5tnr0377vk6dc1endb7.apps.googleusercontent.com",
      "googleClientIdAndroid": "809036959951-icb3n1i65bij3kbc4bnqujkg0mede8hl.apps.googleusercontent.com",
      "googleClientIdIos": "",
      "eas": {
        "projectId": "b3591dc4-18de-435d-83c5-e5cc711c8760"
      }
    },
    "scheme": "nomadway",
    "owner": "crazynodota3"
  }
}
