# ============================================
# NomadWay Backend Environment Configuration
# ============================================

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:19000

# ----- NVIDIA AI (RAG + Chat) -----
# Get keys at https://build.nvidia.com/
# Embeddings key (for ingestion + query embedding)
NVIDIA_EMBED_API_KEY=
# Chat / LLM key
NVIDIA_LLM_API_KEY=
# Base URL (OpenAI-compatible)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Models
NVIDIA_EMBED_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
NVIDIA_LLM_MODEL=minimaxai/minimax-m2.7
# Generation tuning
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
# Retrieval tuning
RAG_TOP_K=8
RAG_INDEX_PATH=data/rag-index.json

# ----- Legacy OpenAI (kept for fallback; leave blank to disable) -----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_TOKENS=512

# ----- Google OAuth -----
# Create OAuth client IDs at https://console.cloud.google.com/apis/credentials
# You may need separate client IDs per platform (web/android/ios).
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_IOS=

# ----- JWT -----
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ----- Database (Prisma) -----
DATABASE_URL=

# ----- Email (optional) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=NomadWay <noreply@nomadway.kz>

# ----- Cloudinary (optional, for uploads) -----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
